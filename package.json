{
  "name": "auto-mmo-rpg",
  "version": "1.0.0",
  "description": "A fully autonomous 2D pixel-art idle RPG built with vanilla JS and HTML5 Canvas",
  "scripts": {
    "start": "npx serve .",
    "dev": "npx serve . -l 8090",
    "test:combat-log": "node tests/combat-log.playwright.js",
    "test:progression": "node tests/progression.playwright.js",
    "test:expedition": "node tests/offline-expedition.playwright.js",
    "test:bot": "node tests/smarter-bot.playwright.js"
  },
  "keywords": [
    "game",
    "rpg",
    "idle",
    "canvas",
    "pixel-art"
  ],
  "license": "MIT",
  "private": true,
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
